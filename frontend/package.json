{
  "name": "ai-quarrel",
  "version": "1.0.0",
  "description": "AI吵架生成器 - 微信小程序",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "dev:weapp": "cross-env TARO_APP_API_ENV=dev taro build --type weapp --watch",
    "build:weapp:dev": "cross-env TARO_APP_API_ENV=dev taro build --type weapp",
    "build:weapp:prod": "cross-env TARO_APP_API_ENV=prod taro build --type weapp",
    "build:weapp": "npm run build:weapp:prod",
    "dev:h5": "cross-env TARO_APP_API_ENV=dev taro build --type h5 --watch",
    "build:h5:dev": "cross-env TARO_APP_API_ENV=dev taro build --type h5",
    "build:h5:prod": "cross-env TARO_APP_API_ENV=prod taro build --type h5",
    "build:h5": "npm run build:h5:prod"
  },
  "dependencies": {
    "@antmjs/vantui": "^3.7.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@tarojs/components": "4.0.9",
    "@tarojs/plugin-framework-react": "4.0.9",
    "@tarojs/plugin-platform-h5": "4.0.9",
    "@tarojs/plugin-platform-weapp": "4.0.9",
    "@tarojs/react": "4.0.9",
    "@tarojs/runtime": "4.0.9",
    "@tarojs/taro": "4.0.9",
    "cross-env": "^10.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-react": "^7.18.0",
    "@tarojs/cli": "4.0.9",
    "@tarojs/webpack5-runner": "4.0.9",
    "@types/react": "^18.2.0",
    "babel-preset-taro": "4.0.9",
    "sass": "^1.69.0",
    "typescript": "^5.1.0",
    "webpack": "5.91.0"
  }
}
